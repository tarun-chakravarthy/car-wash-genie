datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}


model User {
  id            Int         @id @default(autoincrement())
  email         String      @unique
  name          String
  passwordHash  String
  role          Role        @default(CUSTOMER)
  createdAt     DateTime    @default(now())
}

enum Role {
  CUSTOMER
  BUSINESS_OWNER
}